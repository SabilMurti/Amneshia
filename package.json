{
  "name": "amneshia",
  "version": "2.0.0",
  "description": "🧠 Unified memory hub for AI agents. Knowledge graph + FTS5 full-text search via MCP. One memory, all agents.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "amneshia": "dist/index.js"
  },
  "files": [
    "dist",
    "dist-ui",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "memory",
    "ai",
    "agent",
    "knowledge-graph",
    "sqlite",
    "fts5"
  ],
  "author": "Sabil Murti <github.com/SabilMurti>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SabilMurti/Amneshia.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^11.0.0",
    "commander": "^13.0.0",
    "express": "^5.2.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^22.20.1",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
